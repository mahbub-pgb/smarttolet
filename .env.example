# ===== App =====
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# ===== Database =====
MONGO_URI=mongodb://127.0.0.1:27017/smart_tolet

# ===== Redis =====
REDIS_URL=redis://127.0.0.1:6379

# ===== JWT =====
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ===== OTP =====
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

# ===== Bcrypt =====
BCRYPT_SALT_ROUNDS=12

# ===== Cloudinary (fallback; DB settings take precedence) =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== Google Maps (fallback; DB settings take precedence) =====
GOOGLE_MAPS_API_KEY=

# ===== SMS Provider (fallback; DB settings take precedence) =====
SMS_PROVIDER=mock
SMS_API_KEY=
SMS_SENDER_ID=SmartToLet

# ===== Super Admin seed =====
SUPER_ADMIN_MOBILE=+8801700000000
SUPER_ADMIN_EMAIL=admin@smarttolet.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

# ===== Payment Gateways =====
BKASH_BASE_URL=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
